# Normalize line endings: LF in repo, platform-native on checkout
* text=auto

# Force LF for config/script files (don't let Windows convert these)
.claude/**     text eol=lf
*.json         text eol=lf
*.md           text eol=lf
*.py           text eol=lf
*.ts           text eol=lf
*.tsx          text eol=lf
*.css          text eol=lf
*.html         text eol=lf
*.sh           text eol=lf

# Binaries — no conversion
*.png binary
*.jpg binary
*.ico binary
*.woff2 binary
