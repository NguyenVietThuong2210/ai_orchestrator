# ── Backend selection ─────────────────────────────────────────────────────────
# claude_code = Mode B (default) — no API key needed, uses Claude Code Pro session
# api         = Mode A           — requires ANTHROPIC_API_KEY + credit
AI_BACKEND=claude_code

# ── Mode A — Anthropic API ────────────────────────────────────────────────────
# Required only when AI_BACKEND=api
ANTHROPIC_API_KEY=sk-ant-...

# Model per agent (Mode A)
PM_MODEL=claude-haiku-4-5-20251001
ANALYSER_MODEL=claude-opus-4-7
ENGINEER_MODEL=claude-sonnet-4-6
QA_MODEL=claude-sonnet-4-6

# ── Mode B — Claude Code (Pro subscription) ───────────────────────────────────
# No API key needed. Override model per agent if desired.
# Default: all agents use Sonnet 4.6 (Opus not available without API key)
PM_MODEL_B=claude-haiku-4-5-20251001
ANALYSER_MODEL_B=claude-sonnet-4-6
ENGINEER_MODEL_B=claude-sonnet-4-6
QA_MODEL_B=claude-sonnet-4-6

# ── Pipeline limits ───────────────────────────────────────────────────────────
MAX_QA_ITERATIONS=3
MAX_QA_ANALYSER_ITERATIONS=2
HUMAN_GATE_TIMEOUT_HOURS=24

# ── Storage ───────────────────────────────────────────────────────────────────
CHECKPOINT_DB=./data/checkpoints.sqlite
ARTIFACT_DIR=./artifacts

# ── Observability (optional) ──────────────────────────────────────────────────
LOG_LEVEL=INFO
LANGFUSE_PUBLIC_KEY=
LANGFUSE_SECRET_KEY=
