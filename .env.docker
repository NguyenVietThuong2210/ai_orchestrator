# Copy this to .env and fill in real values before running docker-compose

# ── PostgreSQL ────────────────────────────────────────────────────────────────
POSTGRES_DB=orchestrator
POSTGRES_USER=orchestrator
POSTGRES_PASSWORD=change_me_in_production

# ── Agent backend ─────────────────────────────────────────────────────────────
# claude_code = Mode B (Pro subscription, no API key needed)
# api         = Mode A (requires ANTHROPIC_API_KEY)
AI_BACKEND=claude_code

# Required only for Mode A:
# ANTHROPIC_API_KEY=sk-ant-...

# ── Models ────────────────────────────────────────────────────────────────────
PM_MODEL_B=claude-haiku-4-5-20251001
ANALYSER_MODEL_B=claude-sonnet-4-6
ENGINEER_MODEL_B=claude-sonnet-4-6
QA_MODEL_B=claude-sonnet-4-6

# ── Pipeline ──────────────────────────────────────────────────────────────────
MAX_QA_ITERATIONS=3
MAX_QA_ANALYSER_ITERATIONS=2
LOG_LEVEL=INFO
